---
interface Props {
  variant?: 'full' | 'mark';
  size?: number;
  color?: string;
  class?: string;
}
const { variant = 'mark', size = 28, color = 'var(--forest)', class: cls } = Astro.props;
---
{
  variant === 'full' ? (
    <svg width={size} height={size} viewBox="0 0 140 140" aria-hidden="true" class={cls}>
      <path d="M60 25 A46 46 0 1 1 84 27" fill="none" stroke="var(--forest)" stroke-width="11" stroke-linecap="round" />
      <path d="M60 25 A46 46 0 1 1 84 27" fill="none" stroke="var(--forest-deep)" stroke-width="1.1" stroke-dasharray="0.6 6.6" opacity="0.5" />
      <path d="M44 70 A26 26 0 0 1 70 44" fill="none" stroke="var(--ochre)" stroke-width="2" opacity="0.4" />
      <path d="M84 27 C 87 15, 78 8, 69 9 C 63 9, 59 12, 57 17 L 66 22 C 73 24, 81 26, 84 27 Z" fill="var(--forest)" />
      <path d="M59 26 L67 19 L63 27 Z" fill="var(--forest)" />
      <circle cx="74" cy="15.5" r="3.2" fill="var(--terra)" opacity="0.3" />
      <circle cx="74" cy="15.5" r="1.8" fill="var(--forest-deep)" />
      <path d="M57 16 L49 12 M50.5 12.7 L46.5 10.5 M50.5 12.7 L47.5 15" fill="none" stroke="var(--terra)" stroke-width="1.1" stroke-linecap="round" />
      <circle cx="63" cy="12.5" r="0.8" fill="var(--forest-deep)" opacity="0.55" />
    </svg>
  ) : (
    <svg width={size} height={size} viewBox="0 0 28 28" aria-hidden="true" class={cls} style={`color:${color}`}>
      <path d="M19 5.5 A10 10 0 1 1 11 4.4" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" />
      <circle cx="20" cy="6" r="3.4" fill="currentColor" />
      <circle cx="20.6" cy="5.2" r="1" fill="var(--paper)" />
    </svg>
  )
}
