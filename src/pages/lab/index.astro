---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const entries = (await getCollection('lab', ({ data }) => !data.draft)).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);
---
<BaseLayout title="Lab — Jeffrey Boruszak" description="Generative and interactive language experiments.">
  <h1>Lab</h1>
  <p class="intro">Generative and interactive experiments.</p>
  {
    entries.length === 0 ? (
      <p>No experiments yet.</p>
    ) : (
      <ul class="entry-list">
        {entries.map((entry) => (
          <li class="entry-row">
            <a class="title" href={`/lab/${entry.id}`}>{entry.data.title}</a>
          </li>
        ))}
      </ul>
    )
  }
  <style>
    .intro { color: var(--ink-soft); margin-top: 0; }
  </style>
</BaseLayout>
